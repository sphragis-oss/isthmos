{
  "rules": [
    {
      "tool": "mcp__atlassian__*",
      "drop_keys": ["self", "expand", "avatarUrls", "iconUrl", "profilePicture", "accountType", "timeZone"],
      "max_items": 50,
      "keep_last": 5,
      "min_bytes": 800
    },
    {
      "tool": "Bash",
      "max_lines": 400,
      "keep_last": 80,
      "dedup": true,
      "min_bytes": 16384
    },
    {
      "tool": "mcp__github__*",
      "drop_keys": ["node_id", "gravatar_id", "avatar_url", "events_url", "followers_url", "following_url", "gists_url", "organizations_url", "received_events_url", "repos_url", "starred_url", "subscriptions_url"],
      "max_items": 50,
      "keep_last": 5,
      "min_bytes": 800
    }
  ]
}
